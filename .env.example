# GeoGuard AI - Environment Configuration

# Application
APP_NAME="GeoGuard AI"
APP_VERSION="1.0.0"
DEBUG=True
API_PREFIX="/api/v1"

# Database Configuration
# Default: SQLite file for local development (requires no setup)
DATABASE_URL="sqlite+aiosqlite:///./geoguard.db"
# Production/Docker: PostgreSQL + PostGIS (uncomment to use)
# DATABASE_URL="postgresql+asyncpg://geoguard:geoguard@localhost:5432/geoguard_db"

# Redis Cache/Queue
REDIS_URL="redis://localhost:6379/0"

# JWT Authentication
JWT_SECRET_KEY="geoguard-secret-key-change-in-production-use-secure-random"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Allowed Origins (comma-separated list in settings, or JSON array in FastAPI config)
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# External API Keys (Optional for basic demo)
OPENWEATHER_API_KEY=""
NASA_EARTHDATA_TOKEN=""
